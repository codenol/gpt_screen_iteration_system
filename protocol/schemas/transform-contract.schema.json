{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semantic-ui-evolution.local/schemas/transform-contract.schema.json",
  "title": "TransformContracts",
  "type": "object",
  "required": ["contracts"],
  "properties": {
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "version",
          "intent",
          "target",
          "preconditions",
          "effects",
          "invariants",
          "reversibility",
          "reverseStrategy",
          "explainability",
          "validation",
          "revisionLinkage"
        ],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "intent": { "type": "string" },
          "target": {
            "type": "object",
            "required": ["allowedNodeRoles", "allowedWidgetTypes"],
            "properties": {
              "allowedNodeRoles": {
                "type": "array",
                "items": { "type": "string" }
              },
              "allowedWidgetTypes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "preconditions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "invariants": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reversibility": { "enum": ["reversible", "partially_reversible", "irreversible"] },
          "reverseStrategy": { "type": "string" },
          "explainability": {
            "type": "object",
            "required": ["success", "failure"],
            "properties": {
              "success": { "type": "string" },
              "failure": { "type": "string" }
            }
          },
          "validation": { "type": "object" },
          "revisionLinkage": {
            "type": "object",
            "required": ["linkComment", "markCommentApplied"],
            "properties": {
              "linkComment": { "type": "boolean" },
              "markCommentApplied": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
